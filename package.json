{
  "name": "ai-prompt-sidebar",
  "version": "1.0.0",
  "description": "Chrome extension: AI Prompt Sidebar for Grok & Gemini with financial analysis templates",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "dev": "node esbuild.config.mjs --watch",
    "clean": "rm -rf dist",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/ templates/",
    "format:check": "prettier --check src/ templates/",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "zip": "cd dist && zip -r ../ai-prompt-sidebar.zip ."
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@types/jest": "^29.5.14",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "esbuild": "^0.24.2",
    "eslint": "^9.18.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "prettier": "^3.4.2",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.3"
  }
}
