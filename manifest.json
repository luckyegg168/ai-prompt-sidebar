{
  "manifest_version": 3,
  "name": "AI Prompt Sidebar",
  "version": "1.0.0",
  "description": "在 AI 聊天平台注入浮動側邊欄，提供金融分析、AI 圖片、AI 影片提示詞模板，支援一鍵填入並送出。",
  "permissions": ["storage", "activeTab", "alarms", "notifications"],
  "optional_permissions": ["contextMenus"],
  "host_permissions": [
    "https://x.com/*",
    "https://grok.com/*",
    "https://gemini.google.com/*",
    "https://chatgpt.com/*",
    "https://claude.ai/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; style-src 'self' 'unsafe-inline'"
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/i/grok*",
        "https://grok.com/*",
        "https://gemini.google.com/*",
        "https://chatgpt.com/*",
        "https://claude.ai/*"
      ],
      "js": ["content.js"],
      "css": ["sidebar.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "toggle-sidebar": {
      "suggested_key": {
        "default": "Ctrl+Shift+P",
        "mac": "Command+Shift+P"
      },
      "description": "切換 AI Prompt Sidebar"
    },
    "open-management": {
      "suggested_key": {
        "default": "Ctrl+Shift+M",
        "mac": "Command+Shift+M"
      },
      "description": "開啟提示詞管理頁面"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "defaults.json",
        "stock-analysis.json",
        "image-generation.json",
        "video-generation.json",
        "general.json"
      ],
      "matches": [
        "https://x.com/*",
        "https://grok.com/*",
        "https://gemini.google.com/*",
        "https://chatgpt.com/*",
        "https://claude.ai/*"
      ]
    }
  ]
}
